{
  "name": "daybook-enterprise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build": "tsc && vite build",
    "build:exe": "node scripts/build-exe.mjs",
    "electron:dev": "concurrently \"vite\" \"tsx watch server/index.ts\" \"wait-on http-get://localhost:5173 && electron .\"",
    "electron:build": "node scripts/build-electron.mjs",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.daybook.app",
    "productName": "Daybook",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server.cjs",
        "to": "server.cjs"
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/electron/**",
          "!**/electron-builder/**",
          "!**/.cache/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Daybook"
    },
    "asar": false
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.0",
    "html2canvas-pro": "^2.0.4",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.70.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@yao-pkg/pkg": "^6.20.0",
    "autoprefixer": "^10.0.0",
    "concurrently": "^8.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^4.0.0",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
